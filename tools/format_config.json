{
  "schema_version": 1,
  "formatting": {
    "line_width": 120,
    "indent_width": 4,
    "tab_width": 4
  },
  "macro_categories": {
    "calling_convention": [
      "CALLBACK",
      "WINAPI"
    ],
    "statement_like_parameters": [
      "X"
    ]
  },
  "stream_shift": {
    "configuration_methods": [
      "std::boolalpha",
      "std::noboolalpha",
      "std::showbase",
      "std::noshowbase",
      "std::showpoint",
      "std::noshowpoint",
      "std::showpos",
      "std::noshowpos",
      "std::skipws",
      "std::noskipws",
      "std::uppercase",
      "std::nouppercase",
      "std::unitbuf",
      "std::nounitbuf",
      "std::internal",
      "std::left",
      "std::right",
      "std::dec",
      "std::hex",
      "std::oct",
      "std::fixed",
      "std::scientific",
      "std::hexfloat",
      "std::defaultfloat",
      "std::setbase",
      "std::setfill",
      "std::setprecision",
      "std::setw",
      "std::resetiosflags",
      "std::setiosflags",
      "std::emit_on_flush",
      "std::noemit_on_flush"
    ]
  },
  "include_sorting": {
    "main_include": {
      "include_is_main_regex": "(Test)?$",
      "quote": true
    },
    "groups": [
      {
        "name": "windows_socket",
        "regex": "^<(winsock2|ws2tcpip)\\.h>$"
      },
      {
        "name": "windows_core",
        "regex": "^<windows\\.h>$"
      },
      {
        "name": "system",
        "regex": "^<.*>$"
      },
      {
        "name": "vendored",
        "regex": "^\"vendor/.*\"$"
      },
      {
        "name": "project",
        "regex": "^\".*\"$"
      }
    ]
  }
}
