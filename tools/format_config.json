{
  "schema_version": 1,
  "formatting": {
    "line_width": 120,
    "indent_width": 4,
    "tab_width": 4,
    "continuation_indent_width": 4
  },
  "macro_categories": {
    "calling_convention": [
      "CALLBACK",
      "WINAPI"
    ]
  },
  "include_sorting": {
    "main_include": {
      "include_is_main_regex": "(Test)?$",
      "quote": true
    },
    "groups": [
      {
        "name": "windows_socket",
        "regex": "^<(winsock2|ws2tcpip)\\.h>$"
      },
      {
        "name": "windows_core",
        "regex": "^<windows\\.h>$"
      },
      {
        "name": "system",
        "regex": "^<.*>$"
      },
      {
        "name": "vendored",
        "regex": "^\"vendor/.*\"$"
      },
      {
        "name": "project",
        "regex": "^\".*\"$"
      }
    ]
  }
}
