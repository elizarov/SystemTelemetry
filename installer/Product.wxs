<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package
    Name="CaseDash"
    Manufacturer="Roman Elizarov"
    Version="$(var.ProductVersion)"
    UpgradeCode="4E1B19A7-7B3F-4E1F-8B2E-7E6B3B0E57A5"
    Scope="perMachine">
    <MajorUpgrade AllowDowngrades="yes" />
    <MediaTemplate EmbedCab="yes" />
    <WixVariable Id="WixUIDialogBmp" Value="$(var.CaseDashDialogBmpPath)" />
    <WixVariable Id="WixUIBannerBmp" Value="CaseDash_WixUIBannerBmp.bmp" />
    <Icon Id="CaseDashAppIcon" SourceFile="..\resources\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="CaseDashAppIcon" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Run CaseDash now" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="CASEDASH_INSTALLFOLDER">
      <RegistrySearch
        Id="FindRememberedInstallFolder"
        Root="HKLM"
        Key="SOFTWARE\Roman Elizarov\CaseDash"
        Name="InstallFolder"
        Type="raw" />
    </Property>
    <CustomAction
      Id="LaunchCaseDash"
      FileRef="CaseDashExeFile"
      ExeCommand="/bring-to-front"
      Execute="immediate"
      Impersonate="yes"
      Return="asyncNoWait" />
    <util:CloseApplication
      Id="CloseCaseDashOnUninstall"
      Target="CaseDash.exe"
      Description="CaseDash is running and must close before uninstall can finish."
      Condition="REMOVE=&quot;ALL&quot;"
      CloseMessage="yes"
      ElevatedCloseMessage="yes"
      Timeout="10"
      TerminateProcess="1"
      RebootPrompt="no" />
    <SetProperty
      Id="RemoveCaseDashRunValue"
      Value="&quot;[SystemFolder]reg.exe&quot; delete &quot;HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Run&quot; /v CaseDash /f"
      Before="RemoveCaseDashRunValue"
      Sequence="execute"
      Condition="REMOVE=&quot;ALL&quot;" />
    <CustomAction
      Id="RemoveCaseDashRunValue"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />
    <UIRef Id="CaseDashUI_InstallDirNoLicense_$(sys.BUILDARCHSHORT)" />

    <UI>
      <Publish
        Dialog="CaseDashExitDialog"
        Control="Finish"
        Event="DoAction"
        Value="LaunchCaseDash"
        Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <InstallExecuteSequence>
      <Custom
        Action="override Wix4CloseApplications_$(sys.BUILDARCHSHORT)"
        Before="RemoveFiles"
        Condition="REMOVE=&quot;ALL&quot; AND VersionNT &gt; 400" />
      <Custom Action="RemoveCaseDashRunValue" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <Feature Id="MainFeature" Title="CaseDash" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="CaseDash" />
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="CaseDashExeComponent" Guid="71D937AF-A37F-43E9-BE22-20C6E4C6554B" Bitness="always64">
        <File Id="CaseDashExeFile" Source="$(var.CaseDashExePath)" KeyPath="yes" />
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\Roman Elizarov\CaseDash"
          Name="InstallFolder"
          Type="string"
          Value="[INSTALLFOLDER]" />
        <util:RemoveFolderEx
          Id="RemoveInstallFolderTree"
          Property="CASEDASH_INSTALLFOLDER"
          On="uninstall"
          Condition="NOT UPGRADINGPRODUCTCODE" />
        <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
        <ServiceControl
          Id="RemoveCashDashService"
          Name="CashDashService"
          Stop="uninstall"
          Remove="uninstall"
          Wait="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
