#!/bin/sh

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 1

staged_files=$(git -C "$repo_root" diff --cached --name-only --diff-filter=ACMR -- 'src/**/*.cpp' 'src/**/*.h' 'tests/**/*.cpp' 'tests/**/*.h')
if [ -z "$staged_files" ]; then
    exit 0
fi

stash_created=0
stash_message="systemtelemetry-pre-commit-format"

if ! git -C "$repo_root" diff --quiet --no-ext-diff --ignore-submodules -- || [ -n "$(git -C "$repo_root" ls-files --others --exclude-standard)" ]; then
    stash_output=$(git -C "$repo_root" stash push --keep-index --include-untracked -q -m "$stash_message" 2>&1)
    stash_status=$?
    if [ $stash_status -ne 0 ]; then
        echo "pre-commit: unable to stash unstaged changes"
        echo "$stash_output"
        exit $stash_status
    fi

    if [ -z "$stash_output" ] || [ "$stash_output" != "No local changes to save" ]; then
        stash_created=1
    fi
fi

restore_stash() {
    if [ $stash_created -eq 1 ]; then
        if ! git -C "$repo_root" stash pop -q >/dev/null 2>&1; then
            echo "pre-commit: formatted staged files, but failed to restore unstaged changes from stash"
            echo "Run 'git stash list' and restore the top '$stash_message' entry manually."
            exit 1
        fi
    fi
}

powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$repo_root/tools/run_clang_format.ps1" -Root "$repo_root" -Mode fix -Scope staged -Restage
format_status=$?

if [ $format_status -ne 0 ]; then
    restore_stash
    exit $format_status
fi

restore_stash
exit 0
