IDD_UNSAVED_LAYOUT_EDIT DIALOGEX 0, 0, 220, 84
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_DLGMODALFRAME
CAPTION "CaseDash"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "", IDC_UNSAVED_LAYOUT_EDIT_MAIN, 8, 8, 204, 16
    LTEXT           "", IDC_UNSAVED_LAYOUT_EDIT_CONTENT, 8, 28, 204, 20
    DEFPUSHBUTTON   "Save", IDC_UNSAVED_LAYOUT_EDIT_SAVE, 43, 60, 40, 14
    PUSHBUTTON      "Discard", IDC_UNSAVED_LAYOUT_EDIT_DISCARD, 89, 60, 46, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 141, 60, 40, 14
END

