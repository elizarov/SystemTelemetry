#include <winres.h>
#include "resource.h"

1 24 "SystemTelemetry.manifest"
IDI_APP_ICON ICON "app.ico"
IDR_PANEL_ICON_CPU PNG "cpu.png"
IDR_PANEL_ICON_GPU PNG "gpu.png"
IDR_PANEL_ICON_NETWORK PNG "network.png"
IDR_PANEL_ICON_STORAGE PNG "storage.png"
IDR_PANEL_ICON_TIME PNG "time.png"
IDR_CONFIG_TEMPLATE RCDATA "config.ini"
IDR_LOCALIZATION_CATALOG RCDATA "localization.ini"

IDD_CUSTOM_SCALE DIALOGEX 0, 0, 176, 62
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_DLGMODALFRAME
CAPTION "Custom Scale"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Scale percentage:", IDC_CUSTOM_SCALE_PROMPT, 8, 10, 74, 8
    EDITTEXT        IDC_CUSTOM_SCALE_EDIT, 86, 8, 50, 14, ES_AUTOHSCROLL | ES_LEFT
    LTEXT           "%", -1, 140, 10, 8, 8
    DEFPUSHBUTTON   "OK", IDOK, 69, 38, 45, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 121, 38, 45, 14
END

IDD_LAYOUT_EDIT_CONFIGURATION DIALOGEX 0, 0, 430, 274
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Edit Configuration"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Filter:", IDC_LAYOUT_EDIT_FILTER_LABEL, 8, 10, 26, 8
    EDITTEXT        IDC_LAYOUT_EDIT_FILTER_EDIT, 38, 8, 134, 14, ES_AUTOHSCROLL | ES_LEFT
    CONTROL         "", IDC_LAYOUT_EDIT_TREE, "SysTreeView32", WS_BORDER | WS_TABSTOP | TVS_HASBUTTONS | TVS_HASLINES | TVS_LINESATROOT | TVS_SHOWSELALWAYS, 8, 28, 164, 234
    CONTROL         "", IDC_LAYOUT_EDIT_DIVIDER, "Static", SS_ETCHEDVERT, 178, 8, 1, 254
    LTEXT           "", IDC_LAYOUT_EDIT_TITLE, 186, 10, 236, 10
    LTEXT           "", IDC_LAYOUT_EDIT_LOCATION, 186, 22, 236, 10
    LTEXT           "", IDC_LAYOUT_EDIT_DESCRIPTION, 186, 34, 236, 20
    GROUPBOX        "", IDC_LAYOUT_EDIT_EDITOR_GROUP, 186, 60, 236, 146
    EDITTEXT        IDC_LAYOUT_EDIT_VALUE_EDIT, 198, 80, 210, 14, ES_AUTOHSCROLL | ES_LEFT
    LTEXT           "", IDC_LAYOUT_EDIT_SUMMARY, 198, 80, 210, 24
    LTEXT           "Font name:", IDC_LAYOUT_EDIT_FONT_FACE_LABEL, 198, 80, 34, 8
    COMBOBOX        IDC_LAYOUT_EDIT_FONT_FACE_EDIT, 236, 78, 172, 100, CBS_DROPDOWN | CBS_AUTOHSCROLL | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Size:", IDC_LAYOUT_EDIT_FONT_SIZE_LABEL, 198, 102, 28, 8
    EDITTEXT        IDC_LAYOUT_EDIT_FONT_SIZE_EDIT, 228, 100, 56, 14, ES_AUTOHSCROLL | ES_LEFT
    LTEXT           "Weight:", IDC_LAYOUT_EDIT_FONT_WEIGHT_LABEL, 292, 102, 34, 8
    EDITTEXT        IDC_LAYOUT_EDIT_FONT_WEIGHT_EDIT, 330, 100, 78, 14, ES_AUTOHSCROLL | ES_LEFT
    LTEXT           "", IDC_LAYOUT_EDIT_FONT_SAMPLE, 198, 122, 210, 34
    LTEXT           "", IDC_LAYOUT_EDIT_COLOR_SWATCH, 198, 78, 18, 18, WS_BORDER
    LTEXT           "Hex:", IDC_LAYOUT_EDIT_COLOR_HEX_LABEL, 222, 82, 18, 8
    EDITTEXT        IDC_LAYOUT_EDIT_COLOR_HEX_EDIT, 242, 80, 60, 14, ES_AUTOHSCROLL | ES_LEFT
    PUSHBUTTON      "Pick...", IDC_LAYOUT_EDIT_COLOR_PICK, 344, 78, 64, 14
    LTEXT           "", IDC_LAYOUT_EDIT_COLOR_SAMPLE, 198, 100, 210, 12
    LTEXT           "Red:", IDC_LAYOUT_EDIT_COLOR_RED_LABEL, 198, 122, 18, 8
    EDITTEXT        IDC_LAYOUT_EDIT_COLOR_RED_EDIT, 222, 120, 30, 14, ES_AUTOHSCROLL | ES_LEFT
    CONTROL         "", IDC_LAYOUT_EDIT_COLOR_RED_SLIDER, "msctls_trackbar32", TBS_HORZ | TBS_NOTICKS | WS_TABSTOP, 258, 120, 150, 14
    LTEXT           "Green:", IDC_LAYOUT_EDIT_COLOR_GREEN_LABEL, 198, 144, 24, 8
    EDITTEXT        IDC_LAYOUT_EDIT_COLOR_GREEN_EDIT, 222, 142, 30, 14, ES_AUTOHSCROLL | ES_LEFT
    CONTROL         "", IDC_LAYOUT_EDIT_COLOR_GREEN_SLIDER, "msctls_trackbar32", TBS_HORZ | TBS_NOTICKS | WS_TABSTOP, 258, 142, 150, 14
    LTEXT           "Blue:", IDC_LAYOUT_EDIT_COLOR_BLUE_LABEL, 198, 166, 18, 8
    EDITTEXT        IDC_LAYOUT_EDIT_COLOR_BLUE_EDIT, 222, 164, 30, 14, ES_AUTOHSCROLL | ES_LEFT
    CONTROL         "", IDC_LAYOUT_EDIT_COLOR_BLUE_SLIDER, "msctls_trackbar32", TBS_HORZ | TBS_NOTICKS | WS_TABSTOP, 258, 164, 150, 14
    LTEXT           "First item weight:", IDC_LAYOUT_EDIT_WEIGHT_FIRST_LABEL, 198, 82, 98, 8
    EDITTEXT        IDC_LAYOUT_EDIT_WEIGHT_FIRST_EDIT, 300, 80, 60, 14, ES_AUTOHSCROLL | ES_LEFT
    LTEXT           "Second item weight:", IDC_LAYOUT_EDIT_WEIGHT_SECOND_LABEL, 198, 106, 98, 8
    EDITTEXT        IDC_LAYOUT_EDIT_WEIGHT_SECOND_EDIT, 300, 104, 60, 14, ES_AUTOHSCROLL | ES_LEFT
    LTEXT           "Style:", IDC_LAYOUT_EDIT_METRIC_STYLE_LABEL, 198, 80, 34, 8
    LTEXT           "", IDC_LAYOUT_EDIT_METRIC_STYLE_VALUE, 236, 80, 172, 8
    LTEXT           "Scale:", IDC_LAYOUT_EDIT_METRIC_SCALE_LABEL, 198, 102, 34, 8
    EDITTEXT        IDC_LAYOUT_EDIT_METRIC_SCALE_EDIT, 236, 100, 172, 14, ES_AUTOHSCROLL | ES_LEFT
    LTEXT           "Unit:", IDC_LAYOUT_EDIT_METRIC_UNIT_LABEL, 198, 124, 34, 8
    EDITTEXT        IDC_LAYOUT_EDIT_METRIC_UNIT_EDIT, 236, 122, 172, 14, ES_AUTOHSCROLL | ES_LEFT
    LTEXT           "Label:", IDC_LAYOUT_EDIT_METRIC_LABEL_LABEL, 198, 146, 34, 8
    EDITTEXT        IDC_LAYOUT_EDIT_METRIC_LABEL_EDIT, 236, 144, 172, 14, ES_AUTOHSCROLL | ES_LEFT
    LTEXT           "Binding:", IDC_LAYOUT_EDIT_METRIC_BINDING_LABEL, 198, 168, 34, 8
    COMBOBOX        IDC_LAYOUT_EDIT_METRIC_BINDING_EDIT, 236, 166, 172, 70, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "", IDC_LAYOUT_EDIT_HINT, 198, 176, 210, 18
    LTEXT           "", IDC_LAYOUT_EDIT_STATUS_TEXT, 186, 214, 154, 12
    PUSHBUTTON      "Revert Field", IDC_LAYOUT_EDIT_REVERT, 346, 212, 76, 14
    LTEXT           "Changes preview live. Close this window or turn off Edit layout to save or discard the session.", IDC_LAYOUT_EDIT_FOOTER_HINT, 186, 236, 206, 18
END
